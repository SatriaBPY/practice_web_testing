  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.40.0",
    "allure-playwright": "^3.8.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "mysql2": "^3.22.3"
  }
}
