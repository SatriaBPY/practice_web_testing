{
  "name": "portofolio",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "QA:smoke": "cross-env ENV=QA npx playwright test --grep @smoke --workers=4",
    "QA:regression": "cross-env ENV=QA npx playwright test --grep @regression --workers=4",
    "QA:flaky": "cross-env ENV=QA npx playwright test --grep @flaky --workers=4 --headed",
    "QA:flakyDebug": "cross-env ENV=QA npx playwright test --grep @flaky --debug",
    "QA:serial": "cross-env ENV=QA npx playwright test --grep @serial --workers=4",
    "QA:test2": "cross-env ENV=QA npx playwright test --grep @test2 --workers=4",
    "STAGING:smoke": "cross-env ENV=STAGING npx playwright test --grep @smoke --workers=4",
    "STAGING:regression": "cross-env ENV=STAGING npx playwright test --grep @regression --workers=4",
    "STAGING:flaky": "cross-env ENV=STAGING npx playwright test --grep @flaky --workers=4 --headed",
    "STAGING:flakyDebug": "cross-env ENV=STAGING npx playwright test --grep @flaky --debug",
    "STAGING:serial": "cross-env ENV=STAGING npx playwright test --grep @serial --workers=4",
    "STAGING:test2": "cross-env ENV=STAGING npx playwright test --grep @test2 --workers=4",
    "STAGING:e2e": "cross-env ENV=STAGING npx playwright test --grep @e2e --workers=4",
    "reporter:clean": "npx allure generate allure-results -o allure-report --clean"
  },
  "keywords": [],
